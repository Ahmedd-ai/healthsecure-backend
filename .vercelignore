# Vercel ignores for monorepo (Backend + Frontend)

# ==========================================
# Backend / Python files (not needed for frontend)
# ==========================================
*.py
__pycache__/
*.pyc
.pytest_cache/
venv/
env/
*.db
*.sqlite

# Backend directories
routes/
backend/
ai/
models/

# Test files
test_*.py
test_*.js
test_*.jsx
*.test.js
*.test.jsx

# Documentation (keep README but ignore deployment guides)
*.md
!README.md

# Build scripts
start.bat
run_backend.bat
restart_backend.py

# ==========================================
# Other files to ignore
# ==========================================
.vscode/
.idea/
.DS_Store
Thumbs.db
