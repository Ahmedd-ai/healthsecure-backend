# MongoDB Atlas Connection String
# Replace <password> with your actual MongoDB Atlas password
# Example: mongodb+srv://ahmed_db:<password>@cluster0.3i5uuip.mongodb.net/healthcare?retryWrites=true&w=majority
MONGO_URL=mongodb+srv://ahmed_db:<password>@cluster0.3i5uuip.mongodb.net/healthcare?retryWrites=true&w=majority
